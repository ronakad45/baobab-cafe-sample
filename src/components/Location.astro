---
interface Address { street: string; area: string; city: string }
interface Hours   { label: string; line1: string; line2: string }

interface Props {
  label:     string;
  heading:   string;
  address:   Address;
  hours:     Hours;
  phone:     string;
  phoneHref: string;
  callLabel: string;
  ctaLabel:  string;
  ctaHref:   string;
  mapSrc:    string;
  mapTitle:  string;
}

const { label, heading, address, hours, phone, phoneHref, callLabel, ctaLabel, ctaHref, mapSrc, mapTitle } = Astro.props;
---

<!--
  Background: warm sand (#F0E6D3) — a half-step warmer than the main cream so this
  section reads as distinct from the gallery above without a dramatic colour break.
-->
<section id="location" class="py-20 sm:py-28 bg-[#F0E6D3]">
  <div class="max-w-6xl mx-auto px-5 sm:px-8">

    <!-- Section header -->
    <div class="mb-10 sm:mb-12">
      <div class="w-8 h-0.5 bg-clay mb-5" aria-hidden="true"></div>
      <p class="text-clay text-xs font-semibold tracking-[0.2em] uppercase mb-3">{label}</p>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-charcoal leading-tight">
        {heading}
      </h2>
    </div>

    <!-- Card: details + map -->
    <div class="grid md:grid-cols-2 rounded-2xl overflow-hidden shadow-sm border border-black/[0.06]">

      <!-- Left — details panel -->
      <div class="bg-cream flex flex-col gap-8 p-8 sm:p-10">

        <!-- Address -->
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-clay/10 flex items-center justify-center shrink-0">
            <svg class="w-[1.1rem] h-[1.1rem] text-clay" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-charcoal text-sm mb-1.5">Address</p>
            <address class="not-italic text-charcoal/65 text-sm leading-[1.7]">
              {address.street}<br />
              {address.area}<br />
              {address.city}
            </address>
          </div>
        </div>

        <!-- Hours -->
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-clay/10 flex items-center justify-center shrink-0">
            <svg class="w-[1.1rem] h-[1.1rem] text-clay" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-charcoal text-sm mb-1.5">{hours.label}</p>
            <p class="text-charcoal/65 text-sm">{hours.line1}</p>
            <p class="text-charcoal/65 text-sm">{hours.line2}</p>
          </div>
        </div>

        <!-- Phone (display only) -->
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-full bg-clay/10 flex items-center justify-center shrink-0">
            <svg class="w-[1.1rem] h-[1.1rem] text-clay" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-charcoal text-sm mb-1.5">Phone</p>
            <p class="text-charcoal/65 text-sm">{phone}</p>
          </div>
        </div>

        <!-- CTAs — pushed to bottom of panel on desktop -->
        <div class="flex flex-col sm:flex-row gap-3 mt-auto pt-2">
          <a
            href={phoneHref}
            class="inline-flex items-center justify-center gap-2 border-2 border-clay text-clay hover:bg-clay hover:text-white active:bg-clay-dark font-semibold px-6 py-3 rounded-full transition-colors duration-200 text-sm"
          >
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"/>
            </svg>
            {callLabel}
          </a>

          <a
            href={ctaHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-[#25D366] hover:bg-[#1db954] active:bg-[#18a349] text-white font-semibold px-6 py-3 rounded-full transition-colors duration-200 text-sm shadow-sm"
          >
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 448 512" fill="currentColor" aria-hidden="true">
              <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
            </svg>
            {ctaLabel}
          </a>
        </div>

      </div>

      <!-- Right — Google Maps iframe -->
      <div class="h-72 md:h-auto md:min-h-[420px]">
        <iframe
          src={mapSrc}
          title={mapTitle}
          class="w-full h-full border-0"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>

    </div>
  </div>
</section>
