---
interface Link { label: string; href: string }
interface Props {
  tagline:         string;
  quickLinks:      readonly Link[];
  hours:           { label: string; line1: string; line2: string };
  instagram:       { handle: string; href: string };
  copyrightEntity: string;
}

const { tagline, quickLinks, hours, instagram, copyrightEntity } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-forest text-cream">

  <!-- Main grid -->
  <div class="max-w-6xl mx-auto px-5 sm:px-8 pt-14 pb-12 sm:pt-16 sm:pb-14">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-10 lg:gap-16">

      <!-- Column 1 — Brand -->
      <div class="flex flex-col gap-4 sm:col-span-2 md:col-span-1">
        <a href="/" class="font-serif text-xl font-semibold text-cream leading-snug hover:text-cream/80 transition-colors">
          Baobab Café<br class="hidden sm:block md:hidden" /> & Kitchen
        </a>
        <p class="text-cream/55 text-sm leading-relaxed max-w-[22ch]">
          {tagline}
        </p>
        <!-- Instagram -->
        <a
          href={instagram.href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-cream/55 hover:text-cream transition-colors text-sm mt-2 w-fit"
          aria-label={`Follow Baobab Café on Instagram — ${instagram.handle}`}
        >
          <!-- Instagram icon -->
          <svg class="w-[1.1rem] h-[1.1rem] shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
          {instagram.handle}
        </a>
      </div>

      <!-- Column 2 — Quick Links -->
      <div>
        <p class="text-cream/40 text-xs font-semibold tracking-[0.18em] uppercase mb-5">
          Quick Links
        </p>
        <ul class="flex flex-col gap-3">
          {quickLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-cream/70 hover:text-cream transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3 — Hours -->
      <div>
        <p class="text-cream/40 text-xs font-semibold tracking-[0.18em] uppercase mb-5">
          {hours.label}
        </p>
        <p class="text-cream/70 text-sm mb-1">{hours.line1}</p>
        <p class="text-cream/70 text-sm">{hours.line2}</p>
      </div>

    </div>
  </div>

  <!-- Copyright bar -->
  <div class="border-t border-cream/[0.08]">
    <div class="max-w-6xl mx-auto px-5 sm:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-cream/35 text-xs">
        © {year} {copyrightEntity}. All rights reserved.
      </p>
      <p class="text-cream/25 text-xs">
        Demo / portfolio project
      </p>
    </div>
  </div>

</footer>
