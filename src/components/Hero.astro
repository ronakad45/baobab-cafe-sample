---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/interior.jpg';
import { en } from '../i18n/en';

const { hero, whatsapp } = en;
const orderUrl = `https://wa.me/${whatsapp.number}?text=${encodeURIComponent(whatsapp.orderMessage)}`;
---

<section class="relative min-h-screen flex items-center">
  <!-- Background image — eager-loaded, full bleed -->
  <Image
    src={heroImage}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover object-center"
    loading="eager"
    fetchpriority="high"
    widths={[640, 1024, 1440, 1920]}
    sizes="100vw"
  />

  <!-- Overlay: dark gradient weighted to the left so text reads clearly -->
  <div class="absolute inset-0 bg-gradient-to-r from-charcoal/75 via-charcoal/50 to-charcoal/20"></div>
  <!-- Subtle bottom fade for mobile legibility -->
  <div class="absolute inset-0 bg-gradient-to-t from-charcoal/40 via-transparent to-transparent"></div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-6xl mx-auto px-5 sm:px-8 pt-28 pb-20 sm:pt-36 sm:pb-28">
    <div class="max-w-lg">
      <p class="font-medium text-clay text-xs tracking-[0.22em] uppercase mb-5">
        {hero.location}
      </p>

      <h1 class="font-serif text-[2.75rem] leading-[1.08] sm:text-5xl lg:text-6xl font-bold text-white mb-5">
        Baobab Café<br />& Kitchen
      </h1>

      <p class="text-white/80 text-xl sm:text-2xl font-light mb-10 leading-snug">
        {hero.tagline}
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <!-- Primary: WhatsApp order -->
        <a
          href={orderUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2.5 bg-[#25D366] hover:bg-[#1db954] active:bg-[#18a349] text-white font-semibold px-7 py-3.5 rounded-full transition-colors duration-200 text-sm sm:text-base shadow-lg"
        >
          <svg class="w-[1.1rem] h-[1.1rem] shrink-0" viewBox="0 0 448 512" fill="currentColor" aria-hidden="true">
            <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
          </svg>
          {hero.ctaPrimary}
        </a>

        <!-- Secondary: scroll to menu -->
        <a
          href="#menu"
          class="inline-flex items-center justify-center border-2 border-white/55 hover:border-white text-white hover:bg-white/10 active:bg-white/20 font-semibold px-7 py-3.5 rounded-full transition-all duration-200 text-sm sm:text-base"
        >
          {hero.ctaSecondary}
        </a>
      </div>
    </div>
  </div>
</section>
