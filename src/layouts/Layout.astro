---
import '../styles/global.css';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Baobab Café & Kitchen — Specialty coffee, brunch & light meals in Oyster Bay, Dar es Salaam.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#2D4A3E" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_TZ" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <!-- og:url and og:image should be added once the site has a production domain -->
    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <!-- Fonts: preconnect before stylesheet to reduce latency -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <FloatingWhatsApp />
  </body>
</html>
